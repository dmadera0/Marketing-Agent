# ─────────────────────────────────────────────────────────────────
# BuenaVista AI Content Engine — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Security: one-click review link signing ───────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
REVIEW_TOKEN_SECRET=change-me-to-a-random-secret

# ── Auto-publish: Medium ──────────────────────────────────────────
# Get your token at: https://medium.com/me/settings → Integration tokens
MEDIUM_INTEGRATION_TOKEN=
# Optional: post to a publication instead of your personal profile
MEDIUM_PUBLICATION_ID=

# ── Auto-publish: Company Site ────────────────────────────────────
# Set to 'wordpress' or 'webhook'
SITE_TYPE=wordpress

# WordPress REST API (if SITE_TYPE=wordpress)
# WP_APP_PASSWORD: Settings → Users → Your profile → Application Passwords
WP_URL=https://www.buenavistaaisolutions.com
WP_USER=admin
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Generic webhook (if SITE_TYPE=webhook)
SITE_WEBHOOK_URL=
SITE_WEBHOOK_SECRET=

# ── LinkedIn (approved drafts) ────────────────────────────────────
# OAuth 2.0 app: https://www.linkedin.com/developers/apps
# Required scopes: openid, profile, w_member_social
LINKEDIN_ACCESS_TOKEN=
# Get your URN: GET https://api.linkedin.com/v2/userinfo  → "sub" field → urn:li:person:<sub>
LINKEDIN_PERSON_URN=urn:li:person:XXXXXXXX

# ── Twitter / X (approved drafts) ────────────────────────────────
# Developer portal: https://developer.x.com/en/portal/dashboard
# App needs Read + Write permissions, OAuth 1.0a User Context
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# ── Facebook & Instagram (approved drafts) ────────────────────────
# Meta for Developers: https://developers.facebook.com/apps
# Required permissions: pages_manage_posts, pages_read_engagement,
#   instagram_basic, instagram_content_publish
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_TOKEN=
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=
# Optional: URL of a default image to attach to Instagram posts
# Instagram requires media — set this to your latest blog cover image
INSTAGRAM_IMAGE_URL=

# Blog base URL — replaces [LINK] placeholder in Facebook posts
BLOG_BASE_URL=https://www.buenavistaaisolutions.com/blog

# ── Draft review notifications ────────────────────────────────────
# Email that receives "draft ready for review" notifications
REVIEW_EMAIL=you@buenavistaaisolutions.com

# SMTP config for sending review emails
# Gmail: enable "App Passwords" in your Google account security settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@buenavistaaisolutions.com
SMTP_PASS=your-app-password

# Public URL of this server (used in one-click review email links)
APP_BASE_URL=https://content.buenavistaaisolutions.com

# ── Storage ───────────────────────────────────────────────────────
CONTENT_STORE_DIR=/data/content
